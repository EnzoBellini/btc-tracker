{
  "name": "trackion",
  "private": true,
  "version": "0.0.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/app",
    "dev:landing": "npm run dev --workspace=apps/landing",
    "build": "npm run build --workspace=apps/app",
    "build:landing": "npm run build --workspace=apps/landing",
    "preview:landing": "npm run preview --workspace=apps/landing",
    "start": "npm run start --workspace=apps/app",
    "check": "npm run check --workspace=apps/app",
    "db:push": "npm run db:push --workspace=apps/app",
    "security": "powershell -NoProfile -ExecutionPolicy Bypass -File security/run-full-suite.ps1"
  },
  "engines": {
    "node": "20"
  },
  "overrides": {
    "lodash": "^4.17.23",
    "postcss": "^8.5.10",
    "ws": "^8.18.2",
    "serialize-javascript": "^7.0.5",
    "fast-uri": "^3.1.2",
    "brace-expansion": "^5.0.5"
  },
  "dependencies": {
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0"
  }
}
