# ── Banco (obrigatório em produção) ─────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# ── Sessão (obrigatório em produção — mín. 32 caracteres aleatórios) ───────
SESSION_SECRET=gere-uma-string-aleatoria-longa-aqui

# ── Criptografia MEXC em repouso (obrigatório em produção — mín. 32 chars) ──
ENCRYPTION_KEY=outra-string-aleatoria-diferente-da-session

# ── URL pública do app (links de confirmação no e-mail) ─────────────────────
# Dev: http://localhost:5000  |  Produção: https://app.trackion.app
APP_URL=http://localhost:5000

# ── E-mail via Resend — SEM ISSO O E-MAIL NÃO CHEGA NA CAIXA DE ENTRADA ─────
# 1. Crie conta em https://resend.com
# 2. API Keys → crie uma chave → cole em apps/app/.env (NÃO commitar)
# 3. Verifique o domínio trackion.app no Resend (DNS) antes de enviar em produção
# 4. Testar: npm run test:email --workspace=apps/app  (com TEST_EMAIL=seu@email.com)
# Em dev sem RESEND: o link de confirmação aparece no modal da landing após o cadastro.
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=Trackion <noreply@trackion.app>

# ── Landing (CORS) — origens que podem chamar /api/trial-signup no browser ───
# Onde configurar: apps/app/.env (variável LANDING_ORIGIN)
# Dev: http://localhost:3000  |  Produção: https://trackion.app (e www se usar)
# LANDING_ORIGIN=http://localhost:3000,https://trackion.app,https://www.trackion.app

# ── Billing / Stripe ─────────────────────────────────────────────────────────
# Teste: npm run test:stripe --workspace=apps/app
# Webhook local: stripe listen --forward-to localhost:5000/api/billing/webhook
#
# Chaves (Dashboard → Developers → API keys):
# STRIPE_PUBLISHABLE_KEY=pk_test_...   # ou pk_live_... em produção
# STRIPE_SECRET_KEY=sk_test_...          # ou sk_live_... em produção
#
# Webhook (Dashboard → Developers → Webhooks → Add endpoint):
# URL: https://app.trackion.app/api/billing/webhook
# Eventos: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
# STRIPE_WEBHOOK_SECRET=whsec_...
#
# Preços BRL (R$ 49 / R$ 99 / R$ 199):
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_ELITE=price_...
#
# Preços USD ($20 / $50 / $100) — usuários USA:
# STRIPE_PRICE_STARTER_US=price_...
# STRIPE_PRICE_PRO_US=price_...
# STRIPE_PRICE_ELITE_US=price_...

# ── Admin app separado (apps/admin) ──────────────────────────────────────────
# ADMIN_API_KEY=gere-uma-chave-longa-para-o-painel-admin

# ── Opcional ─────────────────────────────────────────────────────────────────
# NODE_ENV=development
# PORT=5000
