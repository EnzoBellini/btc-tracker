# ── Banco (obrigatório em produção) ─────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# ── Sessão (obrigatório em produção — mín. 32 caracteres aleatórios) ───────
SESSION_SECRET=gere-uma-string-aleatoria-longa-aqui

# ── Criptografia MEXC em repouso (obrigatório em produção — mín. 32 chars) ──
ENCRYPTION_KEY=outra-string-aleatoria-diferente-da-session

# ── URL pública do app (links no e-mail) ─────────────────────────────────────
APP_URL=http://localhost:5000

# ── E-mail via Resend — SEM ISSO O E-MAIL NÃO CHEGA NA CAIXA DE ENTRADA ─────
# 1. Crie conta em https://resend.com
# 2. API Keys → crie uma chave
# 3. Testes: use onboarding@resend.dev (só envia para o e-mail da sua conta Resend)
# 4. Produção: verifique seu domínio e use ex: Trackion <noreply@seudominio.com>
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=onboarding@resend.dev

# ── Landing (CORS do formulário trial) ───────────────────────────────────────
# LANDING_ORIGIN=http://localhost:3000,https://trackion.com.br

# ── Opcional ─────────────────────────────────────────────────────────────────
# NODE_ENV=development
# PORT=5000
