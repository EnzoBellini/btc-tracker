# Onde configurar: apps/landing/.env (build da landing em produção)
#
# API do app (formulário trial). Dev local: deixe VAZIO (proxy Vite → :5000)
# VITE_API_BASE_URL=
# Produção (landing em trackion.app chamando API em app.trackion.app):
# VITE_API_BASE_URL=https://app.trackion.app

# Botões "Começar" / "Entrar" → produto
# VITE_APP_URL=https://app.trackion.app

# FirstPromoter — tracking de cliques na landing (mesmo Account ID do FP)
# VITE_FIRSTPROMOTER_ACCOUNT_ID=
