# =====================================================================
# ARQUIVO DE EXEMPLO DE VARIÁVEIS DE AMBIENTE
# ---------------------------------------------------------------------
# Copie este arquivo para ".env" e preencha com os valores reais.
# NUNCA versione o arquivo ".env" (ele já está no .gitignore).
# =====================================================================

# ---------------------------------------------------------------------
# BANCO DE DADOS POSTGRESQL
# ---------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trackion
DB_USER=postgres
DB_PASSWORD=sua_senha_super_secreta
# Quantos dias sem comprar para considerar o cliente "inativo"
INACTIVE_DAYS=30

# ---------------------------------------------------------------------
# SENDGRID (envio de e-mails)
# ---------------------------------------------------------------------
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxx
# Remetente verificado no painel da SendGrid (Single Sender ou domínio)
EMAIL_FROM=contato@trackioncrypto.com
EMAIL_FROM_NAME=Trackion Crypto

# ---------------------------------------------------------------------
# TWITTER / X (API v2)
# ---------------------------------------------------------------------
# Para leitura de menções basta o Bearer Token (App-only auth).
TWITTER_BEARER_TOKEN=AAAAAAAAAAxxxxxxxxxxxxxxxx
# Termo monitorado (sem @ é opcional; deixe como preferir buscar)
TWITTER_SEARCH_QUERY=@TrackionCrypto
# Quantas menções no máximo buscar por execução (10 a 100)
TWITTER_MAX_RESULTS=50

# ---------------------------------------------------------------------
# SLACK
# ---------------------------------------------------------------------
# Token do tipo Bot (começa com xoxb-)
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxx
# Nome ou ID do canal de destino (ex: #monitoramento-marca ou C01234567)
SLACK_CHANNEL=#monitoramento-marca

# ---------------------------------------------------------------------
# AGENDAMENTO (horário no formato 24h HH:MM)
# ---------------------------------------------------------------------
# Horário em que o e-mail de reengajamento é disparado pela manhã
SCHEDULE_EMAIL_TIME=08:00
# Horário em que o resumo do Twitter é enviado ao Slack no fim do dia
SCHEDULE_TWITTER_TIME=20:00

# Nível de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
